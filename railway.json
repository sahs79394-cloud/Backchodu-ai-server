{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["railway-deploy/**"]
  },
  "deploy": {
    "startCommand": "node railway-deploy/server.mjs",
    "healthcheckPath": "/api/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}